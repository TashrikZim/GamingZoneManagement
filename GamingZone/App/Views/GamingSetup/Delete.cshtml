
@{
    ViewData["Title"] = "Delete";
}

<h1>Delete</h1>

@model BLL.DTOs.GamingSetupDTO

<h1>Delete Gaming Setup</h1>

<h3>Are you sure you want to delete this setup?</h3>

<table class="table table-bordered">
    <tr>
        <th>Setup Name</th>
        <td>@Model.SetupName</td>
    </tr>
    <tr>
        <th>Setup Type</th>
        <td>@Model.SetupType</td>
    </tr>
    <tr>
        <th>Hourly Rate</th>
        <td>@Model.HourlyRate</td>
    </tr>
    <tr>
        <th>Status</th>
        <td>@Model.Status</td>
    </tr>
</table>

<form method="post">
    <input type="hidden" name="id" value="@Model.Id" />

    <input type="submit" name="Decision" value="Yes" class="btn btn-danger" />
    <input type="submit" name="Decision" value="No" class="btn btn-secondary" />
</form>


@model BLL.DTOs.AvailableSetupDTO
@using BLL.DTOs

<h1>Find Available Setup</h1>

<form method="post">
    <input type="text" name="SetupType" value="@Model.SetupType" placeholder="Setup Type" class="form-control" />
    <span class="text-danger">@Html.ValidationMessage("SetupType")</span>

    <input type="submit" value="Search" class="btn btn-primary" />
</form>

<br />

@if (ViewBag.AvailableSetups != null)
{
    var setups = ViewBag.AvailableSetups as List<GamingSetupDTO>;

    <h2>Available Setups</h2>

    if (setups.Count == 0)
    {
        <p>No setup available</p>
    }
    else
    {
        <table class="table">
            <tr>
                <th>Id</th>
                <th>Setup Name</th>
                <th>Setup Type</th>
                <th>Hourly Rate</th>
                <th>Status</th>
                <th>Action</th>
            </tr>

            @foreach (var item in setups)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.SetupName</td>
                    <td>@item.SetupType</td>
                    <td>@item.HourlyRate</td>
                    <td>@item.Status</td>
                    <td>
                        <a href="/Booking/Create/@item.Id" class="btn btn-success">Book</a>
                    </td>
                </tr>
            }
        </table>
    }
}